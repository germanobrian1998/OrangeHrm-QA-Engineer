{
  "name": "orange-hrm-automation-framework",
  "version": "1.0.0",
  "description": "Enterprise Playwright Framework with TypeScript",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf playwright-report test-results",
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:api": "playwright test --grep @api",
    "test:e2e": "playwright test --grep @e2e",
    "lint": "eslint . --ext .ts",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.11.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
