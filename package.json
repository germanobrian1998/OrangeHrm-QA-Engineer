{
  "name": "orange-hrm-automation-framework",
  "version": "1.0.0",
  "description": "Enterprise Playwright Framework with TypeScript",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf playwright-report test-results allure-results allure-report",
    "test:clean": "npm run clean && npx playwright test",
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:api": "playwright test --grep @api",
    "test:e2e": "playwright test --grep @e2e",
    "lint": "eslint . --ext .ts",
    "report": "playwright show-report",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "allure": "npm run report:generate && npm run report:open"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.11.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}